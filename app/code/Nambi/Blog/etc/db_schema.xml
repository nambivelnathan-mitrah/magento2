<?xml version="1.0"?>

<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <table name="nambi_blog_post"
           resource="default"
           engine="innodb"
           comment="Blog Post Table">

        <column xsi:type="int"
                name="post_id"
                padding="10"
                unsigned="true"
                nullable="false"
                identity="true"
                comment="Post ID"/>

        <column xsi:type="varchar"
                name="title"
                nullable="false"
                length="255"
                comment="Title"/>



        <column xsi:type="text"
                name="short_description"
                nullable="true"
                comment="Short Description"/>

        <column xsi:type="text"
                name="long_description"
                nullable="true"
                comment="Long Description"/>

        <column xsi:type="timestamp"
                name="created_at"
                nullable="false"
                default="CURRENT_TIMESTAMP"
                comment="Created At"/>

        <column xsi:type="varchar"
                name="thumbnail"
                nullable="true"
                length="255" 
                comment="Thumbnail"/>
        
        <column xsi:type="smallint" 
                name="status" 
                nullable="false"
                default="1" 
                comment="Status"/>

        <column xsi:type="timestamp" 
                name="last_updated_at"
                nullable="true"
                default="CURRENT_TIMESTAMP"
                on_update="true"
                comment="Last Updated"/>

<column xsi:type="int"
        name="category_id"
        unsigned="true"
        nullable="true"
        comment="Category ID"/>

<constraint xsi:type="foreign"
            referenceId="NAMBI_BLOG_POST_CATEGORY_ID"
            table="nambi_blog_post"
            column="category_id"
            referenceTable="nambi_blog_category"
            referenceColumn="category_id"
            onDelete="SET NULL"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="post_id"/>
        </constraint>

    </table>


<!--category -->

<table name="nambi_blog_category"
       resource="default"
       engine="innodb"
       comment="Blog Category Table">

    <column xsi:type="int"
            name="category_id"
            padding="10"
            unsigned="true"
            nullable="false"
            identity="true"
            comment="Category ID"/>

    <column xsi:type="varchar"
            name="category_name"
            nullable="false"
            length="255"
            comment="Category Name"/>

    <column xsi:type="varchar"
            name="thumbnail"
            nullable="true"
            length="255"
            comment="thumbnail"/>

    <column xsi:type="text"
            name="description"
            nullable="true"
            comment="Description"/>

    <column xsi:type="smallint"
            name="status"
            nullable="false"
            default="1"
            comment="Status"/>


    <column xsi:type="timestamp"
                name="created_at"
                nullable="false"
                default="CURRENT_TIMESTAMP"
                comment="Created At"/>

    <constraint xsi:type="primary"
                referenceId="PRIMARY">

        <column name="category_id"/>

    </constraint>

</table>



</schema>