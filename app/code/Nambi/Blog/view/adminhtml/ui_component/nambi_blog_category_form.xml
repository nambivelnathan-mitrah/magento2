<?xml version="1.0"?>

<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <!-- ================================================= -->
    <!-- FORM CONFIG -->
    <!-- ================================================= -->

    <argument name="data" xsi:type="array">

        <item name="js_config" xsi:type="array">

            <item name="provider" xsi:type="string">
                nambi_blog_category_form.nambi_blog_category_form_data_source
            </item>

            <item name="deps" xsi:type="string">
                nambi_blog_category_form.nambi_blog_category_form_data_source
            </item>

        </item>

        <item name="label" xsi:type="string" translate="true">
            Category
        </item>

        <item name="template" xsi:type="string">
            templates/form/collapsible
        </item>

    </argument>

    <!-- ================================================= -->
    <!-- SETTINGS -->
    <!-- ================================================= -->

    <settings>

        <namespace>
            nambi_blog_category_form
        </namespace>

        <dataScope>
            data
        </dataScope>


        
        <deps>
            <dep>
                nambi_blog_category_form.nambi_blog_category_form_data_source
            </dep>
        </deps>

<buttons>

     <button name="back"
            class="Nambi\Blog\Block\Adminhtml\Category\Edit\BackButton"/> 

    <button name="save"
            class="Nambi\Blog\Block\Adminhtml\Category\Edit\SaveButton"/>

    <button name="delete"
            class="Nambi\Blog\Block\Adminhtml\Category\Edit\DeleteButton"/>



</buttons>

    </settings>

<!--datasource-->

    <dataSource name="nambi_blog_category_form_data_source">

    <argument name="data" xsi:type="array">

        <item name="js_config" xsi:type="array">

            <item name="component" xsi:type="string">
                Magento_Ui/js/form/provider
            </item>

        </item>


    </argument>

    <settings>

        <submitUrl path="nambi_blog/category/save"/>

    </settings>

    <dataProvider class="Nambi\Blog\Model\Category\DataProvider"
                  name="nambi_blog_category_form_data_source">

        <settings>

            <requestFieldName>category_id</requestFieldName>

            <primaryFieldName>category_id</primaryFieldName>

            

        </settings>

    </dataProvider>

</dataSource>

<!-- FIELDSET -->

<fieldset name="general">

    <settings>

        <label translate="true">
            General Information
        </label>

    </settings>

    <!-- STATUS -->

    <field name="status">

        <argument name="data" xsi:type="array">

            <item name="config" xsi:type="array">

                <item name="dataType" xsi:type="string">
                    boolean
                </item>

                <item name="formElement" xsi:type="string">
                    checkbox
                </item>

                <item name="componentType" xsi:type="string">
                    field
                </item>

                <item name="dataScope" xsi:type="string">
                    status
                </item>

                <item name="label" xsi:type="string" translate="true">
                    Enable Category
                </item>

                <item name="prefer" xsi:type="string">
                    toggle
                </item>

                <item name="valueMap" xsi:type="array">

                    <item name="true" xsi:type="number">
                        1
                    </item>

                    <item name="false" xsi:type="number">
                        0
                    </item>

                </item>

                <item name="default" xsi:type="number">
                    1
                </item>

            </item>

        </argument>

    </field>

    <!-- CATEGORY NAME -->

    <field name="category_name">

        <argument name="data" xsi:type="array">

            <item name="config" xsi:type="array">

                <item name="dataType" xsi:type="string">
                    text
                </item>

                <item name="formElement" xsi:type="string">
                    input
                </item>

                <item name="componentType" xsi:type="string">
                    field
                </item>

                <item name="dataScope" xsi:type="string">
                    category_name
                </item>

                <item name="label" xsi:type="string" translate="true">
                    Category Name
                </item>

<item name="validation" xsi:type="array">

    <item name="required-entry" xsi:type="boolean">
        true
    </item>

</item>

            </item>

        </argument>

    </field>

