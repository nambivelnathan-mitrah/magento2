<item name="provider" xsi:type="array"></item>

</argument> -->







    <settings>

        <namespace>nambi_blog_post_form</namespace>

        <dataScope>data</dataScope>

        <deps>
            <dep>
                nambi_blog_post_form.nambi_blog_post_form_data_source
            </dep>
        </deps>


    <buttons>

         <button name="back"
                class="Nambi\Blog\Block\Adminhtml\Post\Edit\BackButton"/>


        <button name="save"
                class="Nambi\Blog\Block\Adminhtml\Post\Edit\SaveButton"/>

    </buttons>


    </settings>

    <!-- DATA SOURCE -->

   <dataSource name="nambi_blog_post_form_data_source">

    <argument name="data" xsi:type="array">

        <item name="js_config" xsi:type="array">

            <item name="component" xsi:type="string">
                Magento_Ui/js/form/provider
            </item>

        </item>

    </argument>

    <settings>

        <submitUrl path="nambi_blog/post/save"/>

    </settings>

    <dataProvider class="Nambi\Blog\Model\Post\DataProvider"
                  name="nambi_blog_post_form_data_source">

        <settings>

            <requestFieldName>
                post_id
            </requestFieldName>

            <primaryFieldName>
                post_id
            </primaryFieldName>

        </settings>

    </dataProvider>

</dataSource>

    <!-- FIELDSET -->

    <fieldset name="general">

        <settings>

            <label translate="true">
               
            </label>

        </settings>


<!--status-->
<field name="status">

    <argument name="data" xsi:type="array">

        <item name="config" xsi:type="array">

            <item name="dataType" xsi:type="string">
                boolean
            </item>

            <item name="formElement" xsi:type="string">
                checkbox
            </item>

            <item name="componentType" xsi:type="string">
                field
            </item>

            <item name="dataScope" xsi:type="string">
                status
            </item>

            <item name="label" xsi:type="string" translate="true">
                Enable Post
            </item>

            <item name="prefer" xsi:type="string">
                toggle
            </item>

            <item name="valueMap" xsi:type="array">

                <item name="true" xsi:type="number">
                    1
                </item>

                <item name="false" xsi:type="number">
                    0
                </item>

            </item>

            <item name="default" xsi:type="number">
                1
            </item>

        </item>

    </argument>

</field>


