        <!-- TITLE -->

<field name="title">

    <argument name="data" xsi:type="array">

        <item name="config" xsi:type="array">

            <item name="dataType" xsi:type="string">
                text
            </item>

            <item name="formElement" xsi:type="string">
                input
            </item>

            <item name="componentType" xsi:type="string">
                field
            </item>

            <item name="dataScope" xsi:type="string">
                title
            </item>

            <item name="sortOrder" xsi:type="number">
                        30
            </item>

<item name="validation" xsi:type="array">

    <item name="required-entry" xsi:type="boolean">
        true
    </item>

</item>

            <item name="label" xsi:type="string" translate="true">
                Title
            </item>

        </item>

    </argument>

</field>

<!--new 22/5--> 

<field name="category_id" sortOrder="25" formElement="select">

    <settings>

        <dataType>text</dataType>

        <label translate="true">
            Category
        </label>

        <dataScope>
            category_id
        </dataScope>

    </settings>

    <formElements>

        <select>

            <settings>

                <options class="Nambi\Blog\Model\Category\Source\CategoryOptions"/>

            </settings>

        </select>

    </formElements>

</field>









<field name="short_description"
       sortOrder="60"
       formElement="wysiwyg">

    <settings>

        <dataType>text</dataType>

        <label translate="true">
            Short Description
        </label>

        <visible>true</visible>

    </settings>

    <formElements>

        <wysiwyg>

            <settings>

                <rows>20</rows>

                <wysiwyg>true</wysiwyg>

            </settings>

        </wysiwyg>

    </formElements>

    <argument name="data" xsi:type="array">

        <item name="config" xsi:type="array">

            <item name="component" xsi:type="string">
                Magento_Ui/js/form/element/wysiwyg
            </item>

            <item name="source" xsi:type="string">
                post
            </item>

            <item name="dataScope" xsi:type="string">
                short_description
            </item>

            <item name="wysiwygConfigData" xsi:type="array">

                <item name="is_pagebuilder_enabled"
                      xsi:type="boolean">
                    false
                </item>

                <item name="toggle_button"
                      xsi:type="boolean">
                    true
                </item>

                <item name="enabled"
                      xsi:type="boolean">
                    true
                </item>

                <item name="add_variables"
                      xsi:type="boolean">
                    true
                </item>

                <item name="add_widgets"
                      xsi:type="boolean">
                    true
                </item>

                <item name="add_images"
                      xsi:type="boolean">
                    true
                </item>

                <item name="add_directives"
                      xsi:type="boolean">
                    true
                </item>

            </item>

        </item>

    </argument>

</field>


<!--thumbnail-->

<field name="thumbnail">

    <argument name="data" xsi:type="array">

        <item name="config" xsi:type="array">

            <item name="dataType" xsi:type="string">
                string
            </item>

            <item name="sortOrder" xsi:type="number">
                 20
            </item>

            <item name="label" xsi:type="string" translate="true">
                Thumbnail
            </item>

            <item name="formElement" xsi:type="string">
                imageUploader
            </item>

            <item name="componentType" xsi:type="string">
                imageUploader
            </item>

            <item name="dataScope" xsi:type="string">
                thumbnail
            </item>

            <item name="elementTmpl" xsi:type="string">
                ui/form/element/uploader/uploader
            </item>

            <item name="previewTmpl" xsi:type="string">
                Magento_Catalog/image-preview
            </item>

            <item name="validation" xsi:type="array">

            <item name="required-entry" xsi:type="boolean">
             true
            </item>

            </item>

            <!-- <item name="required" xsi:type="boolean">
                false
            </item> -->

            <item name="uploaderConfig" xsi:type="array">

                <item name="url" xsi:type="url"
                      path="nambi_blog/post/upload"/>

            </item>

        </item>

    </argument>



</field>


    </fieldset>

</form>



