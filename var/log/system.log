                        <field id="analytics/general/enabled">1</field>
                    </depends>
                </field>
                <field id="vertical" translate="hint label comment" type="select" sortOrder="30" showInDefault="1" showInWebsite="1">
                    <hint>Industry Data</hint>
                    <label>Industry</label>
