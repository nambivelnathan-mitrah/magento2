                    <depends>
                        <field id="search_recommendations_enabled">1</field>
                    </depends>
                </field><field id="search_suggestion_enabled" translate="label comment" type="select" sortOrder="90" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                        <label>Enable Search Suggestions</label>
                        <comment>When you enable this option your site may slow down.</comment>
                        <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    </field><field id="search_suggestion_count" translate="label" type="text" sortOrder="91" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
