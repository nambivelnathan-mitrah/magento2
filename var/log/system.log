                    <label>Last Update</label>
                    <frontend_model>Magento\Config\Block\System\Config\Form\Field\Notification</frontend_model>
                </field>
            </group><group id="adobe_stock_integration" translate="label" type="text" sortOrder="1100" showInDefault="1" showInWebsite="0" showInStore="0">
