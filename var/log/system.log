                        <comment>When you enable this option your site may slow down.</comment>
                        <depends>
                            <field id="search_suggestion_enabled">1</field>
                        </depends>
                    </field><field id="elasticsearch8_server_hostname" translate="label" type="text" sortOrder="61" showInDefault="1" showInWebsite="0" showInStore="0">
