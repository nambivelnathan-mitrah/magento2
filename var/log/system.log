        <class>separator-top</class><label>Catalog</label><tab>catalog</tab><resource>Magento_Catalog::config_catalog</resource><group id="fields_masks" translate="label" type="text" sortOrder="90" showInDefault="1" showInWebsite="1" showInStore="1">
