                <field id="lifetime" translate="label" type="text" sortOrder="10" showInDefault="1">
                    <label>Days Saved in Log</label>
                     <validate>validate-zero-or-greater validate-digits</validate>
                </field>
            </group></section><section id="general" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
