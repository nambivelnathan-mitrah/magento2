            <label>Featured Adobe Payment solution:</label><fieldset_css>magento-payments-top-section magento-payments-recommended-header</fieldset_css><frontend_model>Magento\Paypal\Block\Adminhtml\System\Config\Fieldset\Expanded</frontend_model><attribute type="expanded">1</attribute></group><group id="account" translate="label" sortOrder="1" showInDefault="1" showInWebsite="1">
