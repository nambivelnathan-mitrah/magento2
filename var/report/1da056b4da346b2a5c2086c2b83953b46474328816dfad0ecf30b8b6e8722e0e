 <label>Use Custom Admin Path<\/label>\n                    <source_model>Magento\\Config\\Model\\Config\\Source\\Yesno<\/source_model>\n                    <backend_model>Magento\\Config\\Model\\Config\\Backend\\Admin\\Custompath<\/backend_model>\n                <\/field>\n                <field id=\"custom_path\" translate=\"label comment\" type=\"text\" sortOrder=\"4\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Custom Admin Path<\/label>\n                    <validate>required-entry validate-alphanum<\/validate>\n                    <backend_model>Magento\\Config\\Model\\Config\\Backend\\Admin\\Custompath<\/backend_model>\n                    <depends>\n                        <field id=\"use_custom_path\">1<\/field>\n                    <\/depends>\n                    <comment>You will have to sign in after you save your custom admin path.<\/comment>\n                <\/field>\n            <\/group><group id=\"security\" translate=\"label\" type=\"text\" sortOrder=\"35\" showInDefault=\"1\">\n                <label>Security<\/label>\n                <field id=\"password_reset_link_expiration_period\" translate=\"label comment\" type=\"text\" sortOrder=\"7\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Recovery Link Expiration Period (hours)<\/label>\n                    <comment>Please enter a number 1 or greater in this field.<\/comment>\n                    <validate>required-entry integer validate-greater-than-zero<\/validate>\n                    <backend_model>Magento\\Config\\Model\\Config\\Backend\\Admin\\Password\\Link\\Expirationperiod<\/backend_model>\n                <\/field>\n                <field id=\"use_form_key\" translate=\"label\" type=\"select\" sortOrder=\"10\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Add Secret Key to URLs<\/label>\n                    <source_model>Magento\\Config\\Model\\Config\\Source\\Yesno<\/source_model>\n                    <backend_model>Magento\\Config\\Model\\Config\\Backend\\Admin\\Usesecretkey<\/backend_model>\n                <\/field>\n                <field id=\"use_case_sensitive_login\" translate=\"label\" type=\"select\" sortOrder=\"20\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Login is Case Sensitive<\/label>\n                    <source_model>Magento\\Config\\Model\\Config\\Source\\Yesno<\/source_model>\n                <\/field>\n                <field id=\"session_lifetime\" translate=\"label comment\" sortOrder=\"30\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Admin Session Lifetime (seconds)<\/label>\n                    <comment>Please enter at least 60 and at most 31536000 (one year).<\/comment>\n                    <backend_model>Magento\\Backend\\Model\\Config\\SessionLifetime\\BackendModel<\/backend_model>\n                    <validate>validate-digits validate-digits-range digits-range-60-31536000<\/validate>\n                <\/field>\n            <field id=\"admin_account_sharing\" translate=\"label comment\" type=\"select\" sortOrder=\"5\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Admin Account Sharing<\/label>\n                    <comment>If set to Yes, you can log in from multiple computers into same account. Default setting No improves security.<\/comment>\n                    <source_model>Magento\\Config\\Model\\Config\\Source\\Yesno<\/source_model>\n                <\/field><field id=\"password_reset_protection_type\" translate=\"label\" type=\"select\" sortOrder=\"6\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Password Reset Protection Type<\/label>\n                    <source_model>Magento\\Security\\Model\\Config\\Source\\ResetMethod<\/source_model>\n                <\/field><field id=\"max_number_password_reset_requests\" translate=\"label comment\" type=\"text\" sortOrder=\"7\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Max Number of Password Reset Requests<\/label>\n                    <comment>Limit the number of password reset request per hour. Use 0 to disable.<\/comment>\n                    <validate>required-entry validate-zero-or-greater validate-digits<\/validate>\n                    <depends>\n                        <field id=\"password_reset_protection_type\" separator=\",\" negative=\"1\">0<\/field>\n                    <\/depends>\n                <\/field><field id=\"min_time_between_password_reset_requests\" translate=\"label comment\" type=\"text\" sortOrder=\"8\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Min Time Between Password Reset Requests<\/label>\n                    <comment>Delay in minutes between password reset requests. Use 0 to disable.<\/comment>\n                    <validate>required-entry validate-zero-or-greater validate-digits<\/validate>\n                    <depends>\n                        <field id=\"password_reset_protection_type\" separator=\",\" negative=\"1\">0<\/field>\n                    <\/depends>\n                <\/field><field id=\"lockout_failures\" translate=\"label comment\" sortOrder=\"100\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Maximum Login Failures to Lockout Account<\/label>\n                    <comment>We will disable this feature if the value is empty.<\/comment>\n                    <validate>validate-zero-or-greater validate-digits<\/validate>\n                <\/field><field id=\"lockout_threshold\" translate=\"label\" sortOrder=\"110\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Lockout Time (minutes)<\/label>\n                    <validate>validate-zero-or-greater validate-digits<\/validate>\n                <\/field><field id=\"password_lifetime\" translate=\"label comment\" sortOrder=\"120\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Password Lifetime (days)<\/label>\n                    <comment>We will disable this feature if the value is empty. <\/comment>\n                    <validate>validate-zero-or-greater validate-digits<\/validate>\n                <frontend_model>Magento\\AdminAdobeIms\\Block\\Adminhtml\\System\\Config\\Form\\Field\\Disabled<\/frontend_model><\/field><field id=\"password_is_forced\" translate=\"label\" sortOrder=\"130\" type=\"select\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Password Change<\/label>\n                    <source_model>Magento\\User\\Model\\System\\Config\\Source\\Password<\/source_model>\n                <frontend_model>Magento\\AdminAdobeIms\\Block\\Adminhtml\\System\\Config\\Form\\Field\\Disabled<\/frontend_model><\/field><\/group><group id=\"dashboard\" translate=\"label\" sortOrder=\"40\" showInDefault=\"1\">\n                <label>Dashboard<\/label>\n                <field id=\"enable_charts\" translate=\"label\" type=\"select\" sortOrder=\"1\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Enable Charts<\/label>\n                    <source_model>Magento\\Config\\Model\\Config\\Source\\Yesno<\/source_model>\n                <\/field>\n            <\/group><group id=\"grid\" translate=\"label\" type=\"text\" sortOrder=\"45\" showInDefault=\"1\">\n                <label>Admin Grids<\/label>\n                <field id=\"limit_total_number_of_products\" translate=\"label comment\" type=\"select\" sortOrder=\"1\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Limit Number of Products in Grid<\/label>\n                    <source_model>Magento\\Config\\Model\\Config\\Source\\Yesno<\/source_model>\n                    <comment>Limit total number of products in grid collection.<\/comment>\n                <\/field>\n                <field id=\"records_limit\" translate=\"label comment\" type=\"text\" sortOrder=\"2\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Records Limit<\/label>\n                    <validate>validate-digits validate-digits-range digits-range-20000-<\/validate>\n                    <comment>Limit total number of products in grid collection if their number is greater than this value. Minimum value: 20000.<\/comment>\n                    <depends>\n                        <field id=\"limit_total_number_of_products\">1<\/field>\n                    <\/depends>\n                <\/field>\n            <\/group><group id=\"captcha\" translate=\"label\" type=\"text\" sortOrder=\"50\" showInDefault=\"1\" showInWebsite=\"1\">\n                <label>CAPTCHA<\/label>\n                <field id=\"enable\" translate=\"label\" type=\"select\" sortOrder=\"1\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Enable CAPTCHA in Admin<\/label>\n                    <source_model>Magento\\Config\\Model\\Config\\Source\\Yesno<\/source_model>\n                <\/field>\n                <field id=\"font\" translate=\"label\" type=\"select\" sortOrder=\"2\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Font<\/label>\n                    <source_model>Magento\\Captcha\\Model\\Config\\Font<\/source_model>\n                    <depends>\n                        <field id=\"enable\">1<\/field>\n                    <\/depends>\n                <\/field>\n                <field id=\"forms\" translate=\"label\" type=\"multiselect\" sortOrder=\"3\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Forms<\/label>\n                    <source_model>Magento\\Captcha\\Model\\Config\\Form\\Backend<\/source_model>\n                    <depends>\n                        <field id=\"enable\">1<\/field>\n                    <\/depends>\n                <\/field>\n                <field id=\"mode\" translate=\"label\" type=\"select\" sortOrder=\"4\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Displaying Mode<\/label>\n                    <source_model>Magento\\Captcha\\Model\\Config\\Mode<\/source_model>\n                    <depends>\n                        <field id=\"enable\">1<\/field>\n                    <\/depends>\n                <\/field>\n                <field id=\"failed_attempts_login\" translate=\"label comment\" type=\"text\" sortOrder=\"5\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Number of Unsuccessful Attempts to Login<\/label>\n                    <comment>If 0 is specified, CAPTCHA on the Login form will be always available.<\/comment>\n                    <depends>\n                        <field id=\"mode\">after_fail<\/field>\n                        <field id=\"enable\">1<\/field>\n                    <\/depends>\n                    <frontend_class>required-entry validate-digits<\/frontend_class>\n                <\/field>\n                <field id=\"timeout\" translate=\"label\" type=\"text\" sortOrder=\"6\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>CAPTCHA Timeout (minutes)<\/label>\n                    <depends>\n                        <field id=\"enable\">1<\/field>\n                    <\/depends>\n                    <frontend_class>required-entry validate-digits<\/frontend_class>\n                <\/field>\n                <field id=\"length\" translate=\"label comment\" type=\"text\" sortOrder=\"7\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Number of Symbols<\/label>\n                    <comment>Please specify 8 symbols at the most. Range allowed (e.g. 3-5)<\/comment>\n                    <depends>\n                        <field id=\"enable\">1<\/field>\n                    <\/depends>\n                    <frontend_class>required-entry validate-range range-1-8<\/frontend_class>\n                <\/field>\n                <field id=\"symbols\" translate=\"label comment\" type=\"text\" sortOrder=\"8\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Symbols Used in CAPTCHA<\/label>\n                    <comment>\n                        <![CDATA[Please use only letters (a-z or A-Z) or numbers (0-9) in this field. No spaces or other characters are allowed.<br \/>Similar looking characters (e.g. \"i\", \"l\", \"1\") decrease chance of correct recognition by customer.]]>\n                    <\/comment>\n                    <depends>\n                        <field id=\"enable\">1<\/field>\n                    <\/depends>\n                    <frontend_class>required-entry validate-alphanum<\/frontend_class>\n                <\/field>\n                <field id=\"case_sensitive\" translate=\"label\" type=\"select\" sortOrder=\"9\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Case Sensitive<\/label>\n                    <source_model>Magento\\Config\\Model\\Config\\Source\\Yesno<\/source_model>\n                    <depends>\n                        <field id=\"enable\">1<\/field>\n                    <\/depends>\n                <\/field>\n            <\/group><\/section><section id=\"currency\" translate=\"label\" sortOrder=\"60\" showInDefault=\"1\" showInWebsite=\"1\" showInStore=\"1\">\n            <label>Currency Setup<\/label>\n            <tab>general<\/tab>\n            <resource>Magento_Config::currency<\/resource>\n            <group id=\"options\" translate=\"label\" sortOrder=\"30\" showInDefault=\"1\" showInWebsite=\"1\" showInStore=\"1\">\n                <label>Currency Options<\/label>\n                <field id=\"base\" translate=\"label comment\" type=\"select\" sortOrder=\"1\" showInDefault=\"1\" showInWebsite=\"1\" canRestore=\"1\">\n                    <label>Base Currency<\/label>\n                    <frontend_model>Magento\\Directory\\Block\\Adminhtml\\Frontend\\Currency\\Base<\/frontend_model>\n                    <source_model>Magento\\Config\\Model\\Config\\Source\\Locale\\Currency<\/source_model>\n                    <backend_model>Magento\\Config\\Model\\Config\\Backend\\Currency\\Base<\/backend_model>\n                    <comment>\n                        <![CDATA[Base currency is used for all online payment transactions. The base currency scope is defined by the catalog price scope (\"Catalog\" > \"Price\" > \"Catalog Price Scope\").]]>\n                    <\/comment>\n                <\/field>\n                <field id=\"default\" translate=\"label\" type=\"select\" sortOrder=\"2\" showInDefault=\"1\" showInWebsite=\"1\" showInStore=\"1\" canRestore=\"1\">\n                    <label>Default Display Currency<\/label>\n                    <source_model>Magento\\Config\\Model\\Config\\Source\\Locale\\Currency<\/source_model>\n                    <backend_model>Magento\\Config\\Model\\Config\\Backend\\Currency\\DefaultCurrency<\/backend_model>\n                <\/field>\n                <field id=\"allow\" translate=\"label\" type=\"multiselect\" sortOrder=\"3\" showInDefault=\"1\" showInWebsite=\"1\" showInStore=\"1\" canRestore=\"1\">\n                    <label>Allowed Currencies<\/label>\n                    <source_model>Magento\\Config\\Model\\Config\\Source\\Locale\\Currency<\/source_model>\n                    <backend_model>Magento\\Config\\Model\\Config\\Backend\\Currency\\Allow<\/backend_model>\n                    <can_be_empty>1<\/can_be_empty>\n                <\/field>\n            <\/group>\n            <group id=\"fixerio\" translate=\"label\" sortOrder=\"35\" showInDefault=\"1\">\n                <label>Fixer.io (legacy)<\/label>\n                <field id=\"api_key\" translate=\"label\" type=\"obscure\" sortOrder=\"5\" showInDefault=\"1\">\n                    <label>API Key<\/label>\n                    <config_path>currency\/fixerio\/api_key<\/config_path>\n                    <backend_model>Magento\\Config\\Model\\Config\\Backend\\Encrypted<\/backend_model>\n                    <comment>Use this field if your API Key was generated at Fixer.io. If your key was generated via ApiLayer then use \"Setting &gt; General &gt; Currency setup &gt; Fixer Api via APILayer\" configuration.<\/comment>\n                <\/field>\n                <field id=\"timeout\" translate=\"label\" type=\"text\" sortOrder=\"10\" showInDefault=\"1\">\n                    <label>Connection Timeout in Seconds<\/label>\n                    <validate>validate-zero-or-greater validate-number<\/validate>\n                <\/field>\n            <\/group>\n            <group id=\"fixerio_apilayer\" translate=\"label\" sortOrder=\"35\" showInDefault=\"1\">\n                <label>Fixer Api (APILayer)<\/label>\n                <field id=\"api_key\" translate=\"label\" type=\"obscure\" sortOrder=\"5\" showInDefault=\"1\">\n                    <label>API Key<\/label>\n                    <config_path>currency\/fixerio_apilayer\/api_key<\/config_path>\n                    <backend_model>Magento\\Config\\Model\\Config\\Backend\\Encrypted<\/backend_model>\n                <\/field>\n                <field id=\"timeout\" translate=\"label\" type=\"text\" sortOrder=\"10\" showInDefault=\"1\">\n                    <label>Connection Timeout in Seconds<\/label>\n                    <validate>validate-zero-or-greater validate-number<\/validate>\n                <\/field>\n            <\/group>\n            <group id=\"currencyconverterapi\" translate=\"label\" sortOrder=\"45\" showInDefault=\"1\">\n                <label>Currency Converter API<\/label>\n                <field id=\"api_key\" translate=\"label\" type=\"obscure\" sortOrder=\"5\" showInDefault=\"1\">\n                    <label>API Key<\/label>\n                    <config_path>currency\/currencyconverterapi\/api_key<\/config_path>\n                    <backend_model>Magento\\Config\\Model\\Config\\Backend\\Encrypted<\/backend_model>\n                <\/field>\n                <field id=\"timeout\" translate=\"label\" type=\"text\" sortOrder=\"10\" showInDefault=\"1\">\n                    <label>Connection Timeout in Seconds<\/label>\n                    <validate>validate-zero-or-greater validate-number<\/validate>\n                <\/field>\n            <\/group>\n            <group id=\"import\" translate=\"label\" typ