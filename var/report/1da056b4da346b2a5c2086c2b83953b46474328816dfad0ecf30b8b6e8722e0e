               <field id=\"font\" translate=\"label\" type=\"select\" sortOrder=\"2\" showInDefault=\"1\" showInWebsite=\"1\" canRestore=\"1\">\n                    <label>Font<\/label>\n                    <source_model>Magento\\Captcha\\Model\\Config\\Font<\/source_model>\n                    <depends>\n                        <field id=\"enable\">1<\/field>\n                    <\/depends>\n                <\/field>\n                <field id=\"forms\" translate=\"label comment\" type=\"multiselect\" sortOrder=\"3\" showInDefault=\"1\" showInWebsite=\"1\" canRestore=\"1\">\n                    <label>Forms<\/label>\n                    <source_model>Magento\\Captcha\\Model\\Config\\Form\\Frontend<\/source_model>\n                    <comment>CAPTCHA for \"Create user\", \"Forgot password\", \"Payflow Pro\" forms is always enabled if chosen.<\/comment>\n                    <depends>\n                        <field id=\"enable\">1<\/field>\n                    <\/depends>\n                <\/field>\n                <field id=\"mode\" translate=\"label\" type=\"select\" sortOrder=\"4\" showInDefault=\"1\" showInWebsite=\"1\" canRestore=\"1\">\n                    <label>Displaying Mode<\/label>\n                    <source_model>Magento\\Captcha\\Model\\Config\\Mode<\/source_model>\n                    <depends>\n                        <field id=\"enable\">1<\/field>\n                    <\/depends>\n                <\/field>\n                <field id=\"failed_attempts_login\" translate=\"label comment\" type=\"text\" sortOrder=\"5\" showInDefault=\"1\" showInWebsite=\"1\" canRestore=\"1\">\n                    <label>Number of Unsuccessful Attempts to Login<\/label>\n                    <comment>If 0 is specified, CAPTCHA on the Login form will be always available.<\/comment>\n                    <depends>\n                        <field id=\"enable\">1<\/field>\n                        <field id=\"mode\">after_fail<\/field>\n                    <\/depends>\n                    <frontend_class>required-entry validate-digits<\/frontend_class>\n                <\/field>\n                <field id=\"timeout\" translate=\"label\" type=\"text\" sortOrder=\"6\" showInDefault=\"1\" showInWebsite=\"1\" canRestore=\"1\">\n                    <label>CAPTCHA Timeout (minutes)<\/label>\n                    <depends>\n                        <field id=\"enable\">1<\/field>\n                    <\/depends>\n                    <frontend_class>required-entry validate-digits<\/frontend_class>\n                <\/field>\n                <field id=\"length\" translate=\"label comment\" type=\"text\" sortOrder=\"7\" showInDefault=\"1\" showInWebsite=\"1\" canRestore=\"1\">\n                    <label>Number of Symbols<\/label>\n                    <comment>Please specify 8 symbols at the most. Range allowed (e.g. 3-5)<\/comment>\n                    <depends>\n                        <field id=\"enable\">1<\/field>\n                    <\/depends>\n                    <frontend_class>required-entry validate-range range-1-8<\/frontend_class>\n                <\/field>\n                <field id=\"symbols\" translate=\"label comment\" type=\"text\" sortOrder=\"8\" showInDefault=\"1\" showInWebsite=\"1\" canRestore=\"1\">\n                    <label>Symbols Used in CAPTCHA<\/label>\n                    <comment>\n                        <![CDATA[Please use only letters (a-z or A-Z) or numbers (0-9) in this field. No spaces or other characters are allowed.<br \/>Similar looking characters (e.g. \"i\", \"l\", \"1\") decrease chance of correct recognition by customer.]]>\n                    <\/comment>\n                    <depends>\n                        <field id=\"enable\">1<\/field>\n                    <\/depends>\n                    <frontend_class>required-entry validate-alphanum<\/frontend_class>\n                <\/field>\n                <field id=\"case_sensitive\" translate=\"label\" type=\"select\" sortOrder=\"9\" showInDefault=\"1\" showInWebsite=\"1\" canRestore=\"1\">\n                    <label>Case Sensitive<\/label>\n                    <source_model>Magento\\Config\\Model\\Config\\Source\\Yesno<\/source_model>\n                    <depends>\n                        <field id=\"enable\">1<\/field>\n                    <\/depends>\n                <\/field>\n            <\/group><\/section><tab id=\"customer\" translate=\"label\" sortOrder=\"300\">\n            <label>Customers<\/label>\n        <\/tab><section id=\"webapi\" translate=\"label\" type=\"text\" sortOrder=\"102\" showInDefault=\"1\" showInWebsite=\"1\" showInStore=\"1\">\n            <group id=\"graphql_validation\" translate=\"label\" type=\"text\" sortOrder=\"10\" showInDefault=\"1\" showInWebsite=\"1\" showInStore=\"1\">\n                <label>GraphQl Input Limits<\/label>\n                <field id=\"input_limit_enabled\" translate=\"label\" type=\"select\" sortOrder=\"5\" showInDefault=\"1\" showInWebsite=\"1\" showInStore=\"1\">\n                    <source_model>Magento\\Config\\Model\\Config\\Source\\Yesno<\/source_model>\n                    <label>Enable Input Limits<\/label>\n                    <config_path>graphql\/validation\/input_limit_enabled<\/config_path>\n                <\/field>\n                <field id=\"maximum_page_size\" translate=\"label comment\" type=\"text\" sortOrder=\"15\" showInDefault=\"1\" showInWebsite=\"1\" showInStore=\"1\">\n                    <label>Maximum Page Size<\/label>\n                    <comment>Maximum number of items allowed in a paginated search result.<\/comment>\n                    <config_path>graphql\/validation\/maximum_page_size<\/config_path>\n                    <depends>\n                        <field id=\"input_limit_enabled\">1<\/field>\n                    <\/depends>\n                <\/field>\n                <field id=\"alias_limit_enabled\" translate=\"label\" type=\"select\" sortOrder=\"5\" showInDefault=\"1\" showInWebsite=\"1\" showInStore=\"1\">\n                    <source_model>Magento\\Config\\Model\\Config\\Source\\Yesno<\/source_model>\n                    <label>Enable Maximum Alias Limit<\/label>\n                    <config_path>graphql\/validation\/alias_limit_enabled<\/config_path>\n                <\/field>\n                <field id=\"maximum_alias_allowed\" translate=\"label comment\" type=\"text\" sortOrder=\"15\" showInDefault=\"1\" showInWebsite=\"1\" showInStore=\"1\" canRestore=\"1\">\n                    <label>Maximum Alias Allowed<\/label>\n                    <comment>Maximum number of aliases allowed in a graphql request.<\/comment>\n                    <config_path>graphql\/validation\/maximum_alias_allowed<\/config_path>\n                    <depends>\n                        <field id=\"alias_limit_enabled\">1<\/field>\n                    <\/depends>\n                <\/field>\n            <\/group>\n            <group id=\"graphql_session\" translate=\"label\" type=\"text\" sortOrder=\"20\" showInDefault=\"0\" showInWebsite=\"0\" showInStore=\"0\">\n                <label>GraphQl Session Management<\/label>\n                <field id=\"disabled\" translate=\"label\" type=\"select\" sortOrder=\"20\" showInDefault=\"0\" showInWebsite=\"0\" showInStore=\"0\">\n                    <source_model>Magento\\Config\\Model\\Config\\Source\\Yesno<\/source_model>\n                    <label>Disable session<\/label>\n                    <config_path>graphql\/session\/disable<\/config_path>\n                <\/field>\n            <\/group>\n        <label>Magento Web API<\/label><tab>service<\/tab><resource>Magento_Webapi::config_webapi<\/resource><group id=\"soap\" translate=\"label\" type=\"text\" sortOrder=\"1\" showInDefault=\"1\" showInWebsite=\"1\" showInStore=\"1\">\n                <label>SOAP Settings<\/label>\n                <field id=\"charset\" translate=\"label comment\" type=\"text\" sortOrder=\"10\" showInDefault=\"1\" showInWebsite=\"1\" showInStore=\"1\">\n                    <label>Default Response Charset<\/label>\n                    <comment>If empty, UTF-8 will be used.<\/comment>\n                <\/field>\n            <\/group><group id=\"validation\" translate=\"label\" type=\"text\" sortOrder=\"10\" showInDefault=\"1\" showInWebsite=\"1\" showInStore=\"1\">\n                <label>Web Api Input Limits<\/label>\n                <field id=\"input_limit_enabled\" translate=\"label\" type=\"select\" sortOrder=\"5\" showInDefault=\"1\" showInWebsite=\"1\" showInStore=\"1\">\n                    <source_model>Magento\\Config\\Model\\Config\\Source\\Yesno<\/source_model>\n                    <label>Enable Input Limits<\/label>\n                <\/field>\n                <field id=\"complex_array_limit\" translate=\"label comment\" type=\"text\" sortOrder=\"10\" showInDefault=\"1\" showInWebsite=\"1\" showInStore=\"1\">\n                    <label>Input List Limit<\/label>\n                    <comment>Maximum number of items allowed in an entity's array property.<\/comment>\n                    <depends>\n                        <field id=\"input_limit_enabled\">1<\/field>\n                    <\/depends>\n                <\/field>\n                <field id=\"maximum_page_size\" translate=\"label comment\" type=\"text\" sortOrder=\"15\" showInDefault=\"1\" showInWebsite=\"1\" showInStore=\"1\">\n                    <label>Maximum Page Size<\/label>\n                    <comment>Maximum number of items allowed in a paginated search result.<\/comment>\n                    <depends>\n                        <field id=\"input_limit_enabled\">1<\/field>\n                    <\/depends>\n                <\/field>\n                <field id=\"default_page_size\" translate=\"label comment\" type=\"text\" sortOrder=\"20\" showInDefault=\"1\" showInWebsite=\"1\" showInStore=\"1\">\n                    <label>Default Page Size<\/label>\n                    <comment>Default number of items a paginated search result.<\/comment>\n                <\/field>\n            <\/group><group id=\"jwtauth\" translate=\"label\" type=\"text\" sortOrder=\"260\" showInDefault=\"1\">\n                <label>JWT Authentication<\/label>\n                <field id=\"jwt_alg\" translate=\"label comment\" type=\"select\" sortOrder=\"1\" showInDefault=\"1\">\n                    <label>Algorithm to sign\/encrypt JWTs used for authentication<\/label>\n                    <source_model>Magento\\JwtUserToken\\Model\\Config\\JwtAlgorithmSource<\/source_model>\n                    <comment>Selected algorithm will define JWT type used (JWS or JWE)<\/comment>\n                <\/field>\n                <field id=\"jwe_alg\" translate=\"label comment\" type=\"select\" sortOrder=\"2\" showInDefault=\"1\">\n                    <label>Content encryption algorithm for JWEs<\/label>\n                    <source_model>Magento\\JwtUserToken\\Model\\Config\\JweAlgorithmSource<\/source_model>\n                    <comment>Encryption algorithm for JWT content to be used when JWE algorithm is selected<\/comment>\n                <\/field>\n                <field id=\"customer_expiration\" translate=\"label comment\" type=\"text\" sortOrder=\"3\" showInDefault=\"1\">\n                    <label>Customer JWT Expires In<\/label>\n                    <validate>validate-zero-or-greater validate-number<\/validate>\n                    <comment>(minutes)<\/comment>\n                <\/field>\n                <field id=\"admin_expiration\" translate=\"label comment\" type=\"text\" sortOrder=\"4\" showInDefault=\"1\">\n                    <label>Admin User JWT Expires In<\/label>\n                    <validate>validate-zero-or-greater validate-number<\/validate>\n                    <comment>(minutes)<\/comment>\n                <\/field>\n            <\/group><group id=\"webapisecurity\" translate=\"label\" type=\"text\" sortOrder=\"250\" showInDefault=\"1\">\n                <label>Web API Security<\/label>\n                <field id=\"allow_insecure\" translate=\"label comment\" type=\"select\" sortOrder=\"1\" showInDefault=\"1\">\n                    <label>Allow Anonymous Guest Access<\/label>\n                    <source_model>Magento\\Config\\Model\\Config\\Source\\Yesno<\/source_model>\n                    <comment>This feature applies only to CMS, Catalog and Store APIs. Please consult your developers for details on potential security risks.<\/comment>\n                <\/field>\n            <\/group><\/section><section id=\"web_api\">\n            <group id=\"graphql\" translate=\"label\" type=\"text\" sortOrder=\"50\" showInDefault=\"1\" showInWebsite=\"1\" showInStore=\"1\">\n                <label>GraphQl<\/label>\n                <field id=\"include_dynamic_attributes_as_entity_type_fields\" translate=\"label\" type=\"select\" sortOrder=\"25\" showInDefault=\"1\" showInWebsite=\"1\" showInStore=\"1\">\n                    <label>Include dynamic attributes as entity type fields<\/label>\n                    <source_model>Magento\\Config\\Model\\Config\\Source\\Yesno<\/source_model>\n                    <config_path>web_api\/graphql\/include_dynamic_attributes_as_entity_type_fields<\/config_path>\n                <\/field>\n            <\/group>\n        <\/section><section id=\"cms\" translate=\"label\" type=\"text\" sortOrder=\"1001\" showInDefault=\"1\" showInWebsite=\"1\" showInStore=\"1\">\n            <label>Content Management<\/label>\n            <tab>general<\/tab>\n            <resource>Magento_Cms::config_cms<\/resource>\n            <group id=\"wysiwyg\" translate=\"label\" type=\"text\" sortOrder=\"100\" showInDefault=\"1\" showInWebsite=\"1\" showInStore=\"1\">\n                <label>WYSIWYG Options<\/label>\n                <field id=\"enabled\" translate=\"label\" type=\"select\" sortOrder=\"1\" showInDefault=\"1\" showInWebsite=\"1\" showInStore=\"1\" canRestore=\"1\">\n                    <label>Enable WYSIWYG Editor<\/label>\n                    <source_model>Magento\\Cms\\Model\\Config\\Source\\Wysiwyg\\Enabled<\/source_model>\n                <\/field>\n                <field id=\"editor\" translate=\"label\" type=\"select\" sortOrder=\"2\" showInDefault=\"1\" showInWebsite=\"1\" canRestore=\"1\">\n                    <label>WYSIWYG Editor<\/label>\n                    <source_model>Magento\\Cms\\Model\\Config\\Source\\Wysiwyg\\Editor<\/source_model>\n                    <depends>\n                        <field id=\"enabled\" negative=\"1\">disabled<\/field>\n                    <\/depends>\n                <\/field>\n            <field id=\"use_static_urls_in_catalog\" translate=\"label comment\" type=\"select\" sortOrder=\"10\" showInDefault=\"1\">\n                    <label>Use Static URLs for Media Content in WYSIWYG<\/label>\n                    <comment>Media content will be inserted into the editor as a static URL. Media content is not updated if the system configuration base URL changes.<\/comment>\n                    <source_model>Magento\\Config\\Model\\Config\\Source\\Yesno<\/source_model>\n                    <depends>\n                        <field id=\"enabled\" negative=\"1\">disabled<\/field>\n                    <\/depends>\n                <\/field><\/group>\n        <group id=\"pagebuilder\" translate=\"label\" type=\"text\" sortOrder=\"2000\" showInDefault=\"1\" showInWebsite=\"0\" showInStore=\"0\">\n                <label>Advanced Content Tools<\/label>\n                <field id=\"enabled\" translate=\"label comment\" type=\"select\" sortOrder=\"1\" showInDefault=\"1\" showInWebsite=\"0\" showInStore=\"0\">\n                    <label>Enable Page Builder<\/label>\n                    <source_model>Magento\\Config\\Model\\Config\\Source\\Yesno<\/source_model>\n                    <frontend_model>Magento\\PageBuilder\\Block\\Adminhtml\\System\\Config\\EnableField<\/frontend_model>\n                    <comment>\n                        <![CDATA[Includes advanced tools to design page layouts, add Magento content (Product and Category data, CMS content and Blocks), and format text.<br \/><br \/>For Product Attributes \u2014 Page Builder can be selected as the \u201cinput type\u201d to design layouts and create content.]]>\n                    <\/comment>\n                <\/field>\n                <field id=\"enable_content_preview\" translate=\"label comment\" type=\"select\" sortOrder=\"10\" showInDefault=\"1\" showInWebsite=\"0\" showInStore=\"0\">\n                    <depends>\n                        <field id=\"enabled\">1<\/field>\n                    <\/depends>\n                    <label>Enable Page Builder Content Preview<\/label>\n                    <source_model>Magento\\Config\\Model\\Config\\Source\\Yesno<\/source_model>\n                    <frontend_model>Magento\\PageBuilder\\Block\\Adminhtml\\System\\Config\\EnableField<\/frontend_model>\n                    <comment>\n                        <![CDATA[Preview Page Builder content on product and category editing pages. Setting to \"No\" can improve performance in case several attributes are editable by Page Builder.]]>\n                    <\/comment>\n                <\/field>\n                <field id=\"google_maps_api_key\" translate=\"label comment\" type=\"text\" sortOrder=\"2010\" showInDefault=\"1\" showInWebsite=\"0\" showInStore=\"0\">\n                    <label>Google Maps API Key<\/label>\n                    <comment>\n                        <![CDATA[Enter API key to use the Map content type. <a href=\"https:\/\/developers.google.com\/maps\/documentation\/javascript\/get-api-key\" target=\"_blank\">Get API Key<\/a>.]]>\n                    <\/comment>\n                <\/field>\n                <field id=\"google_maps_api_key_validator\" translate=\"button_label valid_label invalid_label\" sortOrder=\"2011\" showInDefault=\"1\" showInWebsite=\"0\" showInStore=\"0\">\n                    <attribute type=\"button_label\">Test Key<\/attribute>\n                    <attribute type=\"valid_label\">Key is valid<\/attribute>\n                    <attribute type=\"invalid_label\">Key is invalid. Try a different key.<\/attribute>\n                    <attribute type=\"source_field\">cms_pagebuilder_google_maps_api_key<\/attribute>\n                    <frontend_model>Magento\\PageBuilder\\Block\\Adminhtml\\System\\Config\\Form\\Field\\GoogleMapsApiKey<\/frontend_model>\n                <\/field>\n                <field id=\"google_maps_style\" translate=\"label comment\" type=\"textarea\" sortOrder=\"2020\" showInDefault=\"1\" showInWebsite=\"0\" showInStore=\"0\">\n                    <label>Google Maps Style<\/label>\n                    <validate>validate-google-map-style<\/validate>\n                    <comment>\n                        <![CDATA[Paste the Google Maps style JSON code here to change the look and feel of the Map content type. <a href=\"https:\/\/mapstyle.withgoogle.com\/\" target=\"_blank\">Create Map Style<\/a>.]]>\n                    <\/comment>\n                <\/field>\n                <field id=\"column_grid_default\" translate=\"label comment\" type=\"text\" sortOrder=\"2030\" showInDefault=\"1\" showInWebsite=\"0\" showInStore=\"0\" canRestore=\"1\">\n                    <label>Default Column Grid Size<\/label>\n                    <validate>validate-number validate-digits validate-default-grid-size validate-greater-than-one<\/validate>\n                    <comment>\n                        <![CDATA[Grid size determines the default number of columns available.]]>\n                    <\/comment>\n                <\/field>\n                <field id=\"column_grid_max\" translate=\"label comment\" type=\"text\" sortOrder=\"2040\" showInDefault=\"1\" showInWebsite=\"0\" showInStore=\"0\" canRestore=\"1\">\n                    <label>Maximum Column Grid Size<\/label>\n                    <validate>validate-number validate-digits validate-greater-than-one<\/validate>\n                    <comment>\n                        <![CDATA[Maximum grid size determines the maximum amount of columns available.]]>\n                    <\/comment>\n                <\/field>\n            <\/group><\/section><section id=\"oauth\" translate=\"label\" type=\"text\" sortOrder=\"300\" showInDefault=\"1\" showInWebsite=\"1\" showInStore=\"1\">\n            <label>OAuth<\/label>\n            <tab>service<\/tab>\n            <resource>Magento_Integration::config_oauth<\/resource>\n            <group id=\"access_token_lifetime\" translate=\"label\" type=\"text\" sortOrder=\"100\" showInDefault=\"1\">\n                <label>Access Token Expiration<\/label>\n                <field id=\"customer\" translate=\"label comment\" type=\"text\" sortOrder=\"30\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Customer Token Lifetime (hours)<\/label>\n                    <comment>We will disable this feature if the value is empty.<\/comment>\n                    <validate>validate-zero-or-greater validate-number<\/validate>\n                <\/field>\n                <field id=\"admin\" translate=\"label comment\" type=\"text\" sortOrder=\"60\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Admin Token Lifetime (hours)<\/label>\n                    <comment>We will disable this feature if the value is empty.<\/comment>\n                    <validate>validate-zero-or-greater validate-number<\/validate>\n                <\/field>\n            <\/group>\n            <group id=\"cleanup\" translate=\"label\" type=\"text\" sortOrder=\"300\" showInDefault=\"1\">\n                <label>Cleanup Settings<\/label>\n                <field id=\"cleanup_probability\" translate=\"label comment\" type=\"text\" sortOrder=\"10\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Cleanup Probability<\/label>\n                    <comment>Integer. Launch cleanup in X OAuth requests. 0 (not recommended) - to disable cleanup<\/comment>\n                    <validate>required-entry validate-zero-or-greater validate-digits<\/validate>\n                <\/field>\n                <field id=\"expiration_period\" translate=\"label comment\" type=\"text\" sortOrder=\"20\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Expiration Period<\/label>\n                    <comment>Cleanup entries older than X minutes.<\/comment>\n                    <validate>required-entry validate-zero-or-greater validate-number<\/validate>\n                <\/field>\n            <\/group>\n            <group id=\"consumer\" translate=\"label\" type=\"text\" sortOrder=\"400\" showInDefault=\"1\">\n                <label>Consumer Settings<\/label>\n                <field id=\"expiration_period\" translate=\"label comment\" type=\"text\" sortOrder=\"30\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Expiration Period<\/label>\n                    <comment>Consumer key\/secret will expire if not used within X seconds after Oauth token exchange starts.<\/comment>\n                    <validate>required-entry validate-zero-or-greater validate-number<\/validate>\n                <\/field>\n                <field id=\"post_maxredirects\" translate=\"label comment\" type=\"text\" sortOrder=\"30\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>OAuth consumer credentials HTTP Post maxredirects<\/label>\n                    <comment>Number of maximum redirects for OAuth consumer credentials Post request.<\/comment>\n                    <validate>required-entry validate-zero-or-greater validate-digits<\/validate>\n                <\/field>\n                <field id=\"post_timeout\" translate=\"label comment\" type=\"text\" sortOrder=\"30\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>OAuth consumer credentials HTTP Post timeout<\/label>\n                    <comment>Timeout for OAuth consumer credentials Post request within X seconds.<\/comment>\n                    <validate>required-entry validate-zero-or-greater validate-number<\/validate>\n                <\/field>\n                <field id=\"enable_integration_as_bearer\" translate=\"label\" type=\"select\" sortOrder=\"40\" showInDefault=\"1\" showInWebsite=\"1\" showInStore=\"1\">\n                    <source_model>Magento\\Config\\Model\\Config\\Source\\Yesno<\/source_model>\n                    <label>Allow OAuth Access Tokens to be used as standalone Bearer tokens<\/label>\n                <\/field>\n            <\/group>\n            <group id=\"authentication_lock\" translate=\"label\" type=\"text\" sortOrder=\"400\" showInDefault=\"1\">\n                <label>Authentication Locks<\/label>\n                <field id=\"max_failures_count\" translate=\"label comment\" type=\"text\" sortOrder=\"30\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Maximum Login Failures to Lock Out Account<\/label>\n                    <comment>Maximum Number of authentication failures to lock out account.<\/comment>\n                    <validate>required-entry validate-zero-or-greater validate-digits<\/validate>\n                <\/field>\n                <field id=\"timeout\" translate=\"label comment\" type=\"text\" sortOrder=\"30\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>Lockout Time (seconds)<\/label>\n                    <comment>Period of time in seconds after which account will be unlocked.<\/comment>\n                    <validate>required-entry validate-zero-or-greater validate-number<\/validate>\n                <\/field>\n            <\/group>\n        <\/section><section id=\"catalog\" translate=\"label\" type=\"text\" sortOrder=\"40\" showInDefault=\"1\" showInWebsite=\"1\" showInStore=\"1\">\n            <group id=\"search\" translate=\"label\" type=\"text\" sortOrder=\"500\" showInDefault=\"1\" showInWebsite=\"1\" showInStore=\"1\">\n                <field id=\"engine\" translate=\"label\" type=\"select\" sortOrder=\"20\" showInDefault=\"1\" canRestore=\"1\">\n                    <label>