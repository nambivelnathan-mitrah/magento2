<div class="breadcrumbs"><ul class="items"><li class="item home"><a href="<?= $block->getBaseUrl() ?>"> Home</a></li> <li class="item current"><strong>Posts</strong></li></ul></div><h2>All Blog Posts</h2><form method="get" action="<?= $block->getUrl('blog/post/index') ?>" style=" display:flex; gap:10px; align-items:center; margin-bottom:30px; "><input type="text" name="q" placeholder="Search Post Title" value="<?= $block->getRequest()->getParam('q') ?>" style=" width:100%; height:40px; padding:0 10px; "><button type="submit" style=" height:40px; padding:0 20px; cursor:pointer; "> Search</button></form><br> <div style=" display:grid; grid-template-columns:repeat(4, 1fr); gap:20px; "><?php foreach ($block->getPosts() as $post): ?> <div style=" border:1px solid #ccc; padding:15px; min-height:420px; box-sizing:border-box; "><div style=" width:100%; height:180px; overflow:hidden; margin-bottom:15px; "><?php if ($post->getThumbnail()): ?> <img src="<?= $block->getMediaUrl() . $post->getThumbnail() ?>" style=" width:100%; height:180px; object-fit:cover; "><?php endif; ?></div><h3 style=" min-height:60px; text-align:center; "><a href="<?= $block->getUrl( 'blog/post/view', ['id' => $post->getPostId()] ) ?>"><?= $post->getTitle() ?></a></h3><p><strong> Created At:</strong> <?= $post->getCreatedAt() ?></p><p><b>Category:</b> <a href="<?= $block->getUrl( 'blog/post/index', [ 'category_id' => $post->getCategoryId() ] ) ?>"><?= $block->getCategoryName( $post->getCategoryId() ) ?></a></p><?php $shortDescription = strip_tags( $post->getShortDescription() ); ?> <p class="blog-short-description"><?= substr($shortDescription, 0, 100); ?>... <a href="<?= $block->getUrl( 'blog/post/view', ['id' => $post->getPostId()] ) ?>"> Read More</a></p></div><?php endforeach; ?></div><br><br> <!-- <div style="width:100%; display:flex; justify-content:flex-end; margin-top:30px;"></div> --><div class="pagination-wrapper"><div class="pagination-left"><?= $block->getChildHtml('pager'); ?></div></div><style> .pagination-wrapper{ width:100%; margin-top:30px; } .pagination-left{ width:100%; } .pagination-left .toolbar{ display:flex; justify-content:space-between; align-items:center; width:100%; } .pagination-left .pages{ margin-left:auto; } .blog-short-description{ margin-top:15px; line-height:24px; color:#555; } .blog-short-description a{ color:#1979c3; font-weight:600; text-decoration:none; } .blog-short-description a:hover{ text-decoration:underline; }</style>